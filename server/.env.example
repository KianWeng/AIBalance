# ===== Anthropic (Claude) =====
# 登录 console.anthropic.com 后从浏览器 DevTools → Application → Cookies 获取
ANTHROPIC_SESSION_COOKIE=

# ===== OpenAI (Codex / API) =====
# 方式一：API Key（从 platform.openai.com/api-keys 获取）
OPENAI_API_KEY=
# 方式二：Session Token（从 platform.openai.com 登录后获取，可看详细用量）
OPENAI_SESSION_TOKEN=

# ===== Cursor =====
# 登录 cursor.sh 后从浏览器 DevTools → Application → Cookies 获取
CURSOR_SESSION_COOKIE=

# ===== Google (Gemini / AI Studio) =====
# 从 aistudio.google.com 获取 API Key
GOOGLE_API_KEY=

# ===== DeepSeek =====
# 从 platform.deepseek.com/api_keys 获取 API Key
DEEPSEEK_API_KEY=

# ===== 服务配置 =====
# 数据刷新间隔（秒），默认 300 = 5 分钟
REFRESH_INTERVAL=300
# 服务监听端口
SERVER_PORT=8787

# ===== SSL 配置（可选）=====
# 启用 HTTPS，需要提供证书和私钥路径
# SSL_CERT=/path/to/your/certificate.crt
# SSL_KEY=/path/to/your/private.key
